#!/bin/bash

# alt-image-parse 安装脚本
# 检测系统环境并安装必要依赖

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

echo -e "${BLUE}=== alt-image-parse 安装检测 ===${NC}\n"

# 检测操作系统
detect_os() {
    case "$(uname -s)" in
        Darwin*)    echo "macos" ;;
        Linux*)     echo "linux" ;;
        CYGWIN*|MINGW*|MSYS*)    echo "windows" ;;
        *)          echo "unknown" ;;
    esac
}

OS=$(detect_os)
echo -e "操作系统: ${GREEN}$OS${NC}"

# 检测架构
ARCH=$(uname -m)
echo -e "系统架构: ${GREEN}$ARCH${NC}\n"

# 1. 检测 Node.js
check_node() {
    echo -e "${BLUE}[1/3] 检测 Node.js...${NC}"
    if command -v node &> /dev/null; then
        NODE_VERSION=$(node --version)
        echo -e "  ${GREEN}✓ Node.js 已安装${NC} ($NODE_VERSION)"
        return 0
    else
        echo -e "  ${RED}✗ Node.js 未安装${NC}"
        return 1
    fi
}

# 2. 检测项目依赖
check_dependencies() {
    echo -e "\n${BLUE}[2/3] 检测项目依赖...${NC}"
    cd "$SCRIPT_DIR/src"

    if [ -d "node_modules" ]; then
        # 检查 sharp 是否安装
        if [ -d "node_modules/sharp" ]; then
            SHARP_VERSION=$(cat node_modules/sharp/package.json | grep '"version"' | head -1 | sed 's/.*"version": *"\([^"]*\)".*/\1/')
            echo -e "  ${GREEN}✓ Sharp 已安装${NC} (v$SHARP_VERSION)"
            return 0
        else
            echo -e "  ${YELLOW}✗ Sharp 未安装${NC}"
            return 1
        fi
    else
        echo -e "  ${YELLOW}✗ node_modules 不存在${NC}"
        return 1
    fi
}

# 安装项目依赖
install_dependencies() {
    echo -e "${YELLOW}  正在安装项目依赖...${NC}"
    cd "$SCRIPT_DIR/src"

    # 清理旧依赖（如果存在）
    if [ -d "node_modules" ]; then
        echo -e "  ${YELLOW}  清理旧依赖...${NC}"
        rm -rf node_modules package-lock.json
    fi

    # 安装依赖
    npm install

    if [ -d "node_modules/sharp" ]; then
        echo -e "  ${GREEN}✓ 依赖安装完成${NC}"
    else
        echo -e "  ${RED}  依赖安装失败${NC}"
        exit 1
    fi
}

# 3. 检测环境变量
check_env() {
    echo -e "\n${BLUE}[3/3] 检测环境变量...${NC}"

    if [ -n "$DASHSCOPE_API_KEY" ]; then
        echo -e "  ${GREEN}✓ DASHSCOPE_API_KEY 已设置${NC}"
    else
        echo -e "  ${YELLOW}✗ DASHSCOPE_API_KEY 未设置${NC}"
        echo -e "  ${YELLOW}  请设置: export DASHSCOPE_API_KEY=your_key${NC}"
    fi
}

# 主流程
main() {
    local need_deps=false

    # 检测 Node.js
    if ! check_node; then
        echo -e "\n${RED}Node.js 是必需的，请先安装 Node.js 24+${NC}"
        echo -e "${YELLOW}  下载地址: https://nodejs.org/${NC}"
        exit 1
    fi

    # 检测依赖
    if ! check_dependencies; then
        need_deps=true
    fi

    # 检测环境变量
    check_env

    # 如果需要安装
    if [ "$need_deps" = true ]; then
        echo -e "\n${YELLOW}需要安装缺失的组件${NC}"

        echo -e "\n是否安装项目依赖? [Y/n]"
        read -r response
        if [[ "$response" =~ ^([yY][eE][sS]|[yY]|"") ]]; then
            install_dependencies
        else
            echo -e "${RED}项目依赖是必需的，请手动安装后重试${NC}"
            exit 1
        fi
    fi

    # 最终检测
    echo -e "\n${BLUE}=== 安装验证 ===${NC}"

    if command -v node &> /dev/null && [ -d "$SCRIPT_DIR/src/node_modules/sharp" ]; then
        echo -e "${GREEN}✓ alt-image-parse 已就绪！${NC}"
        echo -e "\n使用方法:"
        echo -e "  $SCRIPT_DIR/img-parse <图片路径> --type <类型>"
    else
        echo -e "${RED}✗ 安装未完成，请检查上述错误${NC}"
        exit 1
    fi
}

main "$@"
